<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Angel & Sandra | 21 August 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  :root {
    --cream: #FAF8F4;
    --sand: #E8E2D9;
    --stone: #B8AFA3;
    --ink: #2C2822;
    --soft: #7A6F65;
    --accent: #C4A882;
  }
  html { scroll-behavior: smooth; }
  body {
    font-family: 'Jost', sans-serif;
    background: var(--cream);
    color: var(--ink);
    font-weight: 300;
    letter-spacing: 0.02em;
  }

  nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    display: flex; justify-content: center; gap: 2.5rem;
    padding: 1.2rem 2rem;
    background: rgba(250,248,244,0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--sand);
  }
  nav a {
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    text-decoration: none; color: var(--soft);
    transition: color 0.3s;
  }
  nav a:hover { color: var(--ink); }

  .hero {
    min-height: 100vh;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    text-align: center;
    padding: 6rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute; inset: 0;
    background: radial-gradient(ellipse at 20% 80%, rgba(196,168,130,0.12) 0%, transparent 60%),
                radial-gradient(ellipse at 80% 20%, rgba(196,168,130,0.08) 0%, transparent 50%);
  }
  .hero-eyebrow {
    font-size: 11px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 2rem;
  }
  .hero-names {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(3.5rem, 10vw, 7rem);
    font-weight: 300; line-height: 1.05;
    color: var(--ink);
  }
  .hero-ampersand {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-style: italic; font-weight: 300;
    color: var(--accent); display: block; margin: 0.3rem 0;
  }
  .hero-date {
    margin-top: 2.5rem;
    font-size: 13px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--soft);
  }
  .divider {
    width: 60px; height: 1px;
    background: var(--accent);
    margin: 2rem auto;
  }
  .scroll-hint {
    position: absolute; bottom: 2.5rem; left: 50%; transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 8px;
    font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--stone);
  }
  .scroll-line {
    width: 1px; height: 40px; background: var(--stone);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse { 0%,100%{opacity:0.3;transform:scaleY(1)} 50%{opacity:1;transform:scaleY(1.2)} }

  section { padding: 6rem 2rem; }
  .section-inner { max-width: 780px; margin: 0 auto; }
  .section-label {
    font-size: 10px; letter-spacing: 0.25em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 1rem; text-align: center;
  }
  .section-title {
    font-family: 'Cormorant Garamond', serif;
    font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 300;
    text-align: center; line-height: 1.2; color: var(--ink);
    margin-bottom: 3rem;
  }

  .details-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 2px;
    border: 1px solid var(--sand); border-radius: 2px;
    overflow: hidden;
  }
  .detail-card {
    padding: 2.5rem 2rem; background: white; text-align: center;
    border-right: 1px solid var(--sand);
  }
  .detail-card:last-child { border-right: none; }
  .detail-icon {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--accent); margin-bottom: 1rem;
  }
  .detail-main {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.5rem; font-weight: 300; color: var(--ink);
    line-height: 1.3; margin-bottom: 0.5rem;
  }
  .detail-sub { font-size: 12px; color: var(--stone); letter-spacing: 0.05em; }

  #countdown-section { background: var(--ink); }
  #countdown-section .section-label { color: var(--accent); }
  #countdown-section .section-title { color: var(--cream); }
  .countdown-grid {
    display: flex; justify-content: center; gap: 1px;
    flex-wrap: wrap;
  }
  .count-block {
    padding: 2rem 2.5rem; text-align: center;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    min-width: 120px;
  }
  .count-num {
    font-family: 'Cormorant Garamond', serif;
    font-size: 3.5rem; font-weight: 300; color: var(--cream); line-height: 1;
  }
  .count-label {
    font-size: 10px; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--stone); margin-top: 0.5rem;
  }

  .gallery-placeholder {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: 200px 140px;
    gap: 2px; border-radius: 2px; overflow: hidden;
  }
  .gallery-tile {
    background: var(--sand);
    display: flex; align-items: center; justify-content: center;
    flex-direction: column; gap: 8px;
    color: var(--stone); font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
    cursor: pointer; transition: background 0.3s;
  }
  .gallery-tile:hover { background: #DDD6CB; }
  .gallery-tile:first-child {
    grid-column: span 2; grid-row: span 2;
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-weight: 300; color: var(--soft);
    letter-spacing: 0.05em; text-transform: none;
  }
  .gallery-tile svg { opacity: 0.4; }

  #registry { background: #F5F0E8; }
  .registry-box {
    border: 1px solid var(--sand); background: white;
    padding: 3rem 2.5rem; text-align: center; border-radius: 2px;
    max-width: 480px; margin: 0 auto;
  }
  .registry-text {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.1rem; font-style: italic; color: var(--soft);
    line-height: 1.7; margin-bottom: 2rem;
  }
  .registry-note {
    font-size: 11px; letter-spacing: 0.12em; color: var(--stone); margin-top: 1.5rem;
  }
  .btn {
    display: inline-block; padding: 0.9rem 2.5rem;
    font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase;
    background: var(--ink); color: var(--cream);
    text-decoration: none; border-radius: 1px;
    transition: background 0.3s;
    cursor: pointer; border: none;
  }
  .btn:hover { background: var(--soft); }

  footer {
    text-align: center; padding: 3rem 2rem;
    border-top: 1px solid var(--sand);
  }
  .footer-names {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.8rem; font-style: italic; font-weight: 300;
    color: var(--soft); margin-bottom: 0.5rem;
  }
  .footer-date { font-size: 11px; letter-spacing: 0.18em; color: var(--stone); text-transform: uppercase; }

  @media (max-width: 600px) {
    .gallery-placeholder { grid-template-columns: 1fr 1fr; grid-template-rows: 160px 120px 120px; }
    .gallery-tile:first-child { grid-column: span 2; grid-row: span 1; }
    .count-block { min-width: 80px; padding: 1.5rem; }
    .count-num { font-size: 2.5rem; }
    nav { gap: 1.2rem; }
  }
</style>
</head>
<body>

<nav>
  <a href="#details">Details</a>
  <a href="#gallery">Gallery</a>
  <a href="#registry">Registry</a>
</nav>

<section class="hero">
  <p class="hero-eyebrow">We're getting married</p>
  <h1 class="hero-names">
    Angel<br>
    <span class="hero-ampersand">&amp;</span>
    Sandra
  </h1>
  <div class="divider"></div>
  <p class="hero-date">21 · August · 2026</p>
  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>Scroll</span>
  </div>
</section>

<section id="details">
  <div class="section-inner">
    <p class="section-label">The celebration</p>
    <h2 class="section-title">Wedding Details</h2>
    <div class="details-grid">
      <div class="detail-card">
        <p class="detail-icon">Date</p>
        <p class="detail-main">21 August<br>2026</p>
        <p class="detail-sub">Friday</p>
      </div>
      <div class="detail-card">
        <p class="detail-icon">Venue</p>
        <p class="detail-main">Teak Town<br>Nilambur</p>
        <p class="detail-sub">Kerala, India</p>
      </div>
      <div class="detail-card">
        <p class="detail-icon">Dress code</p>
        <p class="detail-main">Elegant<br>Formals</p>
        <p class="detail-sub">Update this as needed</p>
      </div>
    </div>
  </div>
</section>

<section id="countdown-section">
  <div class="section-inner">
    <p class="section-label">Counting the days</p>
    <h2 class="section-title">Until we say I do</h2>
    <div class="countdown-grid">
      <div class="count-block"><div class="count-num" id="days">—</div><div class="count-label">Days</div></div>
      <div class="count-block"><div class="count-num" id="hours">—</div><div class="count-label">Hours</div></div>
      <div class="count-block"><div class="count-num" id="minutes">—</div><div class="count-label">Minutes</div></div>
      <div class="count-block"><div class="count-num" id="seconds">—</div><div class="count-label">Seconds</div></div>
    </div>
  </div>
</section>

<section id="gallery">
  <div class="section-inner">
    <p class="section-label">Our moments</p>
    <h2 class="section-title">Photo Gallery</h2>
    <div class="gallery-placeholder">
      <div class="gallery-tile">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
        <span style="font-size:13px; color: var(--stone); font-family:'Cormorant Garamond',serif; font-style:italic">Add your favourite photo here</span>
      </div>
      <div class="gallery-tile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
        <span>Photo</span>
      </div>
      <div class="gallery-tile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
        <span>Photo</span>
      </div>
      <div class="gallery-tile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
        <span>Photo</span>
      </div>
      <div class="gallery-tile">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21,15 16,10 5,21"/></svg>
        <span>Photo</span>
      </div>
    </div>
    <p style="text-align:center; font-size:12px; color:var(--stone); margin-top:1.5rem; letter-spacing:0.05em;">
      Replace the placeholders with your own photos when you host the site
    </p>
  </div>
</section>

<section id="registry">
  <div class="section-inner">
    <p class="section-label">Gift registry</p>
    <h2 class="section-title">Your presence is our greatest gift</h2>
    <div class="registry-box">
      <p class="registry-text">
        "For those who wish to honour us with a gift, we have created a small registry to guide you."
      </p>
      <button class="btn" onclick="alert('Add your registry link here — Amazon, Flipkart, or any other platform.')">View Registry</button>
      <p class="registry-note">Paste your registry URL into the button above</p>
    </div>
  </div>
</section>

<footer>
  <p class="footer-names">Angel &amp; Sandra</p>
  <p class="footer-date">21 · August · 2026 &nbsp;·&nbsp; Teak Town, Nilambur</p>
</footer>

<script>
  function updateCountdown() {
    const wedding = new Date('2026-08-21T00:00:00');
    const now = new Date();
    const diff = wedding - now;
    if (diff <= 0) {
      document.getElementById('days').textContent = '0';
      document.getElementById('hours').textContent = '0';
      document.getElementById('minutes').textContent = '0';
      document.getElementById('seconds').textContent = '0';
      return;
    }
    document.getElementById('days').textContent = Math.floor(diff / 86400000);
    document.getElementById('hours').textContent = Math.floor((diff % 86400000) / 3600000);
    document.getElementById('minutes').textContent = Math.floor((diff % 3600000) / 60000);
    document.getElementById('seconds').textContent = Math.floor((diff % 60000) / 1000);
  }
  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
</body>
</html>
